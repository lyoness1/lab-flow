{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lyoness1/lab-flow/schemas/lab-message-create-response-v0.schema.json",
  "title": "LabFlow Lab Message Create Response v0",
  "description": "Response body for POST /lab-messages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_run_id",
    "message_id",
    "state"
  ],
  "properties": {
    "workflow_run_id": {
      "type": "string",
      "pattern": "^wr_[0-9a-f]{12}$",
      "description": "LabFlow processing ID."
    },
    "message_id": {
      "type": "string",
      "description": "Upstream transmission ID from the request."
    },
    "state": {
      "type": "string",
      "const": "RECEIVED",
      "description": "Initial workflow state after ingest."
    }
  }
}
