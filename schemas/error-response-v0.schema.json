{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lyoness1/lab-flow/schemas/error-response-v0.schema.json",
  "title": "LabFlow Error Response v0",
  "description": "Stable error envelope for client-facing API errors.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "code",
    "message",
    "details"
  ],
  "properties": {
    "status": {
      "type": "integer",
      "description": "HTTP status code; mirrors the response status line."
    },
    "code": {
      "type": "string",
      "description": "Machine-readable error type (for example validation_error)."
    },
    "message": {
      "type": "string",
      "description": "Human-readable summary."
    },
    "details": {
      "type": "array",
      "description": "Field-level issues when applicable.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string",
            "description": "Dotted path to the invalid field (for example observations.0.code)."
          },
          "message": {
            "type": "string",
            "description": "What is wrong with the field."
          }
        }
      }
    }
  }
}
